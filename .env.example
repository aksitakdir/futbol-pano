# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: bypasses RLS. Never expose to the client.
# Supabase → Project Settings → API → service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=

# İçerik & cron
ANTHROPIC_API_KEY=
CRON_SECRET=
YOUTUBE_API_KEY=

# Hub V2 — ücretsiz futbol verisi
# Kayıt: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# Kayıt: https://www.api-football.com/ (ücretsiz plan, günlük kota)
FOOTBALL_API_KEY=

# BSD (Bzzoiro Sports Data) — ücretsiz futbol API: xG, xA, pozisyon, 21K+ oyuncu
# Kayıt: https://sports.bzzoiro.com/register/
BSD_API_KEY=
